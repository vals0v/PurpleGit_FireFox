{
  "manifest_version": 3,
  "name": "GitHub Purple Commits",
  "version": "1.0",
  "description": "Replaces green deposit squares with purple ones.",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "purple-commits@your-nickname",
      "strict_min_version": "109.0"
    }
  },

  "icons": {
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "content_scripts": [
    {
      "matches": ["*://*.github.com/*"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ],
  
  "host_permissions": ["*://*.github.com/*"]
}