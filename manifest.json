{
  "manifest_version": 3,
  "name": "GitHub Purple Commits",
  "version": "1.0",
  "description": "Replaces the standard green squares of GitHub contributions with purple ones.",
  "icons": {
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "css": ["style.css"]
    }
  ]
}