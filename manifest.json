{
  "manifest_version": 3,
  "name": "GitHub Purple Commits",
  "version": "1.0",
  "description": "Replaces green contribution squares with purple ones. This extension does not collect any data.",
  
  "browser_specific_settings": {
    "gecko": {
      "id": "purple-commits-extension@my-addon",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "used": ["none"],
        "required": ["none"]
      }
    }
  },
  "icons": {
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.github.com/*"],
      "css": ["style.css"],
      "run_at": "document_start"
    }
  ],
  
  "host_permissions": ["*://*.github.com/*"]
}